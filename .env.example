APP_ENV=development
LOG_LEVEL=INFO

DATA_DIR=

DATA_SOURCE=both

ENABLE_CHAT=true
ENABLE_RELOAD=true
ENABLE_DEBUG_ENDPOINTS=true
ENABLE_META_ENDPOINT=true

MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=The playbook is currently under maintenance. Please try again shortly.

GOOGLE_DOC_ID_MAIN= # Replace with Google Doc ID
GOOGLE_DOC_NODES_MAIN=

GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json

